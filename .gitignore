.DS_Store

# ──────────────────────────────────────────
# Sensitive / local-only — NEVER push
# ──────────────────────────────────────────
backend/              ← running backend (port 3001)
backend_v1/          ← old backend backup
hermes-chat-app/     ← Hermes Chat App (local only)
subagents.json       ← agent config with API keys
agent_skills.json    ← skill definitions
auth.json            ← auth tokens
*.db                 ← SQLite databases
*.db-shm
*.db-wal
.env                 ← environment variables
.env.local
.env.*.local

# ──────────────────────────────────────────
# Dependencies — never push
# ──────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ──────────────────────────────────────────
# macOS
# ──────────────────────────────────────────
.DS_Store
*.swp
*.swo
