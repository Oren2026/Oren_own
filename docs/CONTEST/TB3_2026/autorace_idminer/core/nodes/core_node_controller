#!/usr/bin/env python
# -*- coding: utf-8 -*-

import rospy, roslaunch, os, time
from enum import Enum
from threading import Timer

class CoreNodeController():
    def __init__(self):
        self.ros_package_path = os.path.dirname(os.path.realpath(__file__))
        self.ros_package_path = self.ros_package_path.replace('core/nodes', '')

        # ========== Mission Sequence ==========
        # 完全自己跑，不需要外部 /mission 控制
        self.Mission = Enum('Mission', '''
            Idle
            TrafficLight
            Intersection
            Construction
            Parking
            LevelCrossing
            Tunnel
            Finish
        ''')

        # 每個關卡的執行秒數（秒數到就自動進下一關）
        self.MISSION_DURATION = {
            self.Mission.TrafficLight.value:  8,    # 賭綠燈
            self.Mission.Intersection.value:  6,    # S曲線/圓環
            self.Mission.Construction.value: 6,    # 施工區
            self.Mission.Parking.value:       1,    # 定點停車
            self.Mission.LevelCrossing.value: 12,   # 平交道
            self.Mission.Tunnel.value:        25,   # 隧道（前半）
        }

        # ========== Launcher enum ==========
        self.Launcher = Enum('Launcher', 'dl cl tf isc ct pk mv lcro tun')

        # 追蹤各節點是否已啟動
        self.launchers = {
            'dl':    {'active': False, 'handle': None},
            'cl':    {'active': False, 'handle': None},
            'tf':    {'active': False, 'handle': None},
            'isc':   {'active': False, 'handle': None},
            'ct':    {'active': False, 'handle': None},
            'pk':    {'active': False, 'handle': None},
            'mv':    {'active': False, 'handle': None},
            'lcro':  {'active': False, 'handle': None},
            'tun':   {'active': False, 'handle': None},
        }

        self.uuid = roslaunch.rlutil.get_or_generate_uuid(None, False)

        # ========== State ==========
        self.current_mission = None
        self.t_next_mission  = None
        self.mission_active  = False

        # 啟動後直接從第一關開始
        rospy.loginfo("[Controller] ===== 啟動中，按 Ctrl-C 停止 =====")
        rospy.sleep(1)  # 留時間給 roscore 穩定
        self._start_mission(self.Mission.TrafficLight.value)

        loop_rate = rospy.Rate(10)  # 10hz，非阻塞

        while not rospy.is_shutdown():
            # 檢查時間到，自動進下一關
            if self.mission_active and rospy.Time.now() >= self.t_next_mission:
                self._advance()

            loop_rate.sleep()

    # ============================================================
    # 公共方法：手動跳到指定關卡（除錯用）
    # ============================================================
    def jump_to(self, mission_value):
        """除錯用：立刻跳到指定關卡"""
        rospy.loginfo("[Controller] 強制跳到 %s", self.Mission(mission_value).name)
        self._cancel_timer()
        self._start_mission(mission_value)

    # ============================================================
    # 內部方法
    # ============================================================

    def _start_mission(self, mission_value):
        """開始執行指定關卡"""
        self.current_mission = mission_value
        self.mission_active  = True
        duration = self.MISSION_DURATION.get(mission_value, 30)

        rospy.loginfo("[Controller] ========================================")
        rospy.loginfo("[Controller] 進入關卡: %s (%.0f秒)", self.Mission(mission_value).name, duration)
        rospy.loginfo("[Controller] 目前啟動中的節點: %s", self._active_nodes())
        rospy.loginfo("[Controller] ========================================")

        # 根據關卡開關對應節點
        if mission_value == self.Mission.TrafficLight.value:
            self._launch(self.Launcher.tf, True)
            self._launch(self.Launcher.dl, False)
            self._launch(self.Launcher.cl, False)
            self._launch(self.Launcher.isc, False)
            self._launch(self.Launcher.ct, False)
            self._launch(self.Launcher.pk, False)
            self._launch(self.Launcher.mv, False)
            self._launch(self.Launcher.lcro, False)
            self._launch(self.Launcher.tun, False)

        elif mission_value == self.Mission.Intersection.value:
            self._launch(self.Launcher.tf, False)
            self._launch(self.Launcher.dl, True)
            self._launch(self.Launcher.cl, True)
            self._launch(self.Launcher.isc, True)
            self._launch(self.Launcher.ct, False)
            self._launch(self.Launcher.pk, False)
            self._launch(self.Launcher.mv, False)
            self._launch(self.Launcher.lcro, False)
            self._launch(self.Launcher.tun, False)

        elif mission_value == self.Mission.Construction.value:
            self._launch(self.Launcher.tf, False)
            self._launch(self.Launcher.dl, True)
            self._launch(self.Launcher.cl, True)
            self._launch(self.Launcher.isc, False)
            self._launch(self.Launcher.ct, True)
            self._launch(self.Launcher.pk, False)
            self._launch(self.Launcher.mv, True)
            self._launch(self.Launcher.lcro, False)
            self._launch(self.Launcher.tun, False)

        elif mission_value == self.Mission.Parking.value:
            self._launch(self.Launcher.tf, False)
            self._launch(self.Launcher.dl, False)
            self._launch(self.Launcher.cl, False)
            self._launch(self.Launcher.isc, False)
            self._launch(self.Launcher.ct, False)
            self._launch(self.Launcher.pk, True)
            self._launch(self.Launcher.mv, False)
            self._launch(self.Launcher.lcro, False)
            self._launch(self.Launcher.tun, False)

        elif mission_value == self.Mission.LevelCrossing.value:
            self._launch(self.Launcher.tf, False)
            self._launch(self.Launcher.dl, True)
            self._launch(self.Launcher.cl, True)
            self._launch(self.Launcher.isc, False)
            self._launch(self.Launcher.ct, False)
            self._launch(self.Launcher.pk, False)
            self._launch(self.Launcher.mv, False)
            self._launch(self.Launcher.lcro, True)
            self._launch(self.Launcher.tun, False)

        elif mission_value == self.Mission.Tunnel.value:
            self._launch(self.Launcher.tf, False)
            self._launch(self.Launcher.dl, True)
            self._launch(self.Launcher.cl, True)
            self._launch(self.Launcher.isc, False)
            self._launch(self.Launcher.ct, False)
            self._launch(self.Launcher.pk, False)
            self._launch(self.Launcher.mv, False)
            self._launch(self.Launcher.lcro, False)
            self._launch(self.Launcher.tun, False)
            # 25秒後進 Tunnel 第二階段
            rospy.sleep(25)
            self._launch(self.Launcher.dl, False)
            self._launch(self.Launcher.tun, True)
            rospy.sleep(2)
            self._launch(self.Launcher.mv, True)

        elif mission_value == self.Mission.Finish.value:
            rospy.loginfo("[Controller] ===== 比賽完成 =====")
            self._shutdown_all()

        # 設定下一關計時
        if mission_value != self.Mission.Finish.value:
            self.t_next_mission = rospy.Time.now() + rospy.Duration(duration)
            rospy.loginfo("[Controller] %d 秒後自動進下一關", duration)

    def _advance(self):
        """時間到，進下一關"""
        self.mission_active = False
        current = self.current_mission
        next_mission = current + 1

        if next_mission <= self.Mission.Finish.value:
            rospy.loginfo("[Controller] >> 計時到了，進下一關")
            self._start_mission(next_mission)
        else:
            self._start_mission(self.Mission.Finish.value)

    def _active_nodes(self):
        return [k for k, v in self.launchers.items() if v['active']]

    def _launch(self, launcher_enum, is_start):
        """統一的 launch/shutdown 介面"""
        key = launcher_enum.name.lower()

        if is_start:
            if not self.launchers[key]['active']:
                launch_file = self._get_launch_file(launcher_enum)
                if launch_file is None:
                    rospy.logwarn("[Controller] %s 沒有對應 launch 檔", key)
                    return
                handle = roslaunch.scriptapi.ROSLaunch()
                handle = roslaunch.parent.ROSLaunchParent(
                    self.uuid,
                    [self.ros_package_path + launch_file]
                )
                handle.start()
                self.launchers[key]['handle'] = handle
                self.launchers[key]['active'] = True
                rospy.loginfo("[Controller] 啟動 +++ %s", key)
            else:
                pass  # 已啟動
        else:
            if self.launchers[key]['active']:
                self.launchers[key]['handle'].shutdown()
                self.launchers[key]['handle'] = None
                self.launchers[key]['active'] = False
                rospy.loginfo("[Controller] 關閉 --- %s", key)
            else:
                pass  # 已關閉

    def _get_launch_file(self, launcher_enum):
        mapping = {
            'dl':   'detect/launch/detect_lane.launch',
            'cl':   'control/launch/control_lane.launch',
            'tf':   'detect/launch/detect_traffic_light.launch',
            'isc':  'detect/launch/detect_intersection.launch',
            'ct':   'detect/launch/detect_construction.launch',
            'pk':   'detect/launch/detect_parking.launch',
            'mv':   'control/launch/control_moving.launch',
            'lcro': 'detect/launch/detect_level.launch',
            'tun':  'detect/launch/detect_tunnel.launch',
        }
        return mapping.get(launcher_enum.name.lower())

    def _cancel_timer(self):
        pass  # 非阻塞計時，不需要 cancel

    def _shutdown_all(self):
        for key in self.launchers:
            self._launch(getattr(self.Launcher, key.upper()), False)

# --------------------------------------------------
if __name__ == '__main__':
    rospy.init_node('core_node_controller')
    node = CoreNodeController()
    rospy.spin()
