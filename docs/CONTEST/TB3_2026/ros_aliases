# ===== TB3 2026 AutoRace 任務快捷指令 =====
# 用法：加到 ~/.bashrc 最底部：source ~/catkin_ws/src/turtlebot3_autorace/ros_aliases

# -------- 快速指令 --------

# 任務測試（單一節點）
alias ros1='roslaunch detect detect_traffic_light.launch'
alias ros1cal='roslaunch detect detect_traffic_light.launch mode:=calibration'
alias ros2='roslaunch detect detect_lane.launch && roslaunch detect detect_intersection.launch'
alias ros2cal='roslaunch detect detect_lane.launch mode:=calibration'
alias ros3='roslaunch detect detect_construction.launch'
alias ros3cal='roslaunch detect detect_construction.launch mode:=calibration'
alias ros4='roslaunch detect detect_parking.launch'
alias ros4cal='roslaunch detect detect_parking.launch mode:=calibration'
alias ros5='roslaunch detect detect_lane.launch && roslaunch control control_lane.launch'
alias ros5cal='roslaunch detect detect_lane.launch mode:=calibration'
alias ros6='roslaunch detect detect_level.launch'
alias ros6cal='roslaunch detect detect_level.launch mode:=calibration'
alias ros7='roslaunch detect detect_tunnel.launch'
alias ros7cal='roslaunch detect detect_tunnel.launch mode:=calibration'

# 循線控制
alias rosdl='roslaunch detect detect_lane.launch'
alias rosdlcal='roslaunch detect detect_lane.launch mode:=calibration'
alias roscl='roslaunch control control_lane.launch'
alias rosck='roslaunch control control_moving.launch'

# -------- 狀態機 --------

# core_node_controller（狀態機）
alias rosn='rosrun core core_node_controller.py'
alias rosnc='rosrun core core_node_controller.py'  # 測試模式（未來擴充用）

# 手動觸發 mission（用於測試狀態切換）
alias rosgo1='rostopic pub /mission std_msgs/UInt8 "data: 1"'
alias rosgo2='rostopic pub /mission std_msgs/UInt8 "data: 2"'
alias rosgo3='rostopic pub /mission std_msgs/UInt8 "data: 3"'
alias rosgo4='rostopic pub /mission std_msgs/UInt8 "data: 4"'
alias rosgo5='rostopic pub /mission std_msgs/UInt8 "data: 5"'
alias rosgo6='rostopic pub /mission std_msgs/UInt8 "data: 6"'
alias rosgo7='rostopic pub /mission std_msgs/UInt8 "data: 7"'
alias rosgo8='rostopic pub /mission std_msgs/UInt8 "data: 8"'

# -------- 工具 --------

# rqt 工具捷徑
alias rosrr='rosrun rqt_reconfigure rqt_reconfigure'    # 動態調整參數（滑動條）
alias rosriv='rosrun rqt_image_view rqt_image_view'      # 看影像輸出
alias rosmon='rosrun rqt_robot_monitor rqt_robot_monitor'  # 機器人狀態監控

# 停止所有節點（情急之用）
alias rosstop='pkill -f "roslaunch\|rosrun"'

# 清除畫面 + 顯示執行中節點
alias rosstat='clear && echo "=== Running Nodes ===" && rosnode list 2>/dev/null && echo "=== Active Topics ===" && rostopic list 2>/dev/null | head -20'

# rpi 控制（TurtleBot SSH + 自動設定 ROS 環境）
alias rpi='ssh ubuntu@192.168.0.104'
alias rpienv='ssh ubuntu@192.168.0.104 "export ROS_MASTER_URI=http://192.168.0.103:11311 && export ROS_IP=192.168.0.104"'

# -------- 快速說明 --------

