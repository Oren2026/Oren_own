    "研習1": {
      "name": "道路駕駛、影像辨識",
      "focus": "號誌偵測 + 岔路決策 + 車道跟隨",
      "commands": {
        "network": [
          "sudo nano /etc/netplan/50-cloud-init.yaml  # WiFi設定",
          "sudo netplan apply  # 重啟網路",
          "ifconfig  # 查詢wlan0 IP",
          "ssh ubuntu@192.168.10.101  # 連線TB3"
        ],
        "env": [
          "nano ~/.bashrc  # 環境變數設定（PC與TB3都要）"
        ],
        "mission": [
          "號誌燈號顏色偵測（紅/綠/黃）",
          "車道線跟隨（黃線左、白線右）",
          "岔路左右轉號誌判斷",
          "開始線觸發發車"
        ]
      }
    },
    "研習2": {
      "name": "自動避障、自動停車",
      "focus": "障礙偵測 + 停車格定位 + 停車控制",
      "commands": {
        "mission": [
          "障礙物偵測（固定位置）",
          "停車格掃描（超聲波或視覺）",
          "空車格判斷演算法",
          "定點停車控制（倒車入庫）",
          "停車場駛出導引"
        ]
      }
    },
    "研習3": {
      "name": "SLAM導航",
      "focus": "SLAM建圖 + 平交道等待 + 隧道導航",
      "commands": {
        "slam": [
          "roscore",
          "roslaunch turtlebot3_slam turtlebot3_slam.launch",
          "rosrun turtlebot3_teleop turtlebot3_teleop_key"
        ],
        "mission": [
          "平交道柵欄偵測（紅白條紋）",
          "柵欄升起等待邏輯",
          "隧道入口辨識（全黑區域）",
          "隧道內光源補償失效 → PID盲走",
          "隧道內障礙物偵測"
        ]
      }
    }
  },
