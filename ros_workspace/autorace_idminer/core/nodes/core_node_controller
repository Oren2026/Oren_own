#!/usr/bin/env python
# -*- coding: utf-8 -*-

import rospy, roslaunch, os
from enum import Enum
from std_msgs.msg import UInt8

class CoreNodeController():
    def __init__(self):
        self.ros_package_path = os.path.dirname(os.path.realpath(__file__))
        self.ros_package_path = self.ros_package_path.replace('core/nodes', '')

        # ========== Subscriber ==========
        # 監聽每個 detect node 完成的訊號
        self.sub_mission = rospy.Subscriber('/mission', UInt8, self.cbReceiveMode, queue_size=1)

        # Sub from each mission step data
        # example
        # rospy.Subscriber('/mission/intersection', UInt8, self.cbIntersectionStep, queue_size=1)
        # rospy.Subscriber('/mission/turtlesim', UInt8, self.cbTurtleStep, queue_size=1)

        # ========== Enum ==========
        self.Mission = Enum('Mission', 'Idle TrafficLight Intersection Construction Parking LevelCrossing Tunnel')

        # each mission step enum
        # self.IntersectionStep = Enum('IntersectionStep', 'default process')
        # self.TurtlesimStep = Enum('TurtlesimStep', 'turtlesim turtleteleop')

        # ========== State ==========
        self.is_triggered = False
        self.current_mode = self.Mission.Idle.value
        # self.current_step_intersection = self.IntersectionStep.default.value
        # self.current_setp_turtlesim = self.TurtlesimStep.turtlesim.value

        # launcher enum（對應 detect/ 和 control/ 裡的 launch 檔）
        self.Launcher = Enum('Launcher', 'dl cl tf isc ct pk mv lcro tun ctun')

        # 追蹤各節點是否已啟動（dictionary 版，乾淨管理）
        self.launchers = {
            'dl':    {'active': False, 'handle': None},
            'cl':    {'active': False, 'handle': None},
            'tf':    {'active': False, 'handle': None},
            'isc':   {'active': False, 'handle': None},
            'ct':    {'active': False, 'handle': None},
            'pk':    {'active': False, 'handle': None},
            'mv':    {'active': False, 'handle': None},
            'lcro':  {'active': False, 'handle': None},
            'tun':   {'active': False, 'handle': None},
            'ctun':  {'active': False, 'handle': None},
        }

        self.uuid = roslaunch.rlutil.get_or_generate_uuid(None, False)

        rospy.loginfo("[Controller] ===== 啟動中 =====")

        # 比賽一開始就開啟 tf（交通號誌偵測），不等第一個 /mission
        # detect_traffic_light 偵測到綠燈後會自動發 /mission = Intersection
        rospy.sleep(1)  # 等 roslaunch 系統完全就緒
        self.fnLaunch(self.Launcher.tf.value, True)

        loop_rate = rospy.Rate(10)  # 10hz

        while not rospy.is_shutdown():
            if self.is_triggered == True:
                self.fnControlNode()
            loop_rate.sleep()

    def cbReceiveMode(self, mode_msg):
        rospy.loginfo("[Controller] 收到 /mission = %d", mode_msg.data)
        self.current_mode = mode_msg.data
        self.is_triggered = True

    # create callback function
    # example
    # def cbIntersectionStep(self, mode_msg):
    #     self.current_step_intersection = mode_msg.data
    #     self.is_triggered = True

    # def cbTurtleStep(self, mode_msg):
    #     self.current_setp_turtlesim = mode_msg.data
    #     self.is_triggered = True

    def fnControlNode(self):

        if self.current_mode == self.Mission.TrafficLight.value:  # 2
            rospy.loginfo("[Controller] === TrafficLight ===")
            # 綠燈出現前：只開 tf（檢測），不開 dl/cl（車子先不動）
            # detect_traffic_light 會等綠燈出現，才往前推進並發下一個 /mission
            self.fnLaunch(self.Launcher.tf.value, True)
            # （注意：dl/cl 在 Intersection 階段才開，見下面）

        elif self.current_mode == self.Mission.Intersection.value:  # 3
            rospy.loginfo("[Controller] === Intersection ===")
            # 收到 Intersection 表示綠燈已確認，開始巡線前進
            # 關閉 tf（不再需要紅綠燈檢測）
            self.fnLaunch(self.Launcher.tf.value, False)
            # 開啟 dl + cl（車道檢測 + 車道控制）
            self.fnLaunch(self.Launcher.dl.value, True)
            self.fnLaunch(self.Launcher.cl.value, True)
            # 等 detect_intersection 看到左/右號誌，完成後會自動 pub /mission = Construction

        elif self.current_mode == self.Mission.Construction.value:  # 4
            rospy.loginfo("[Controller] === Construction ===")
            # 關閉 isc（岔路檢測已完成）
            self.fnLaunch(self.Launcher.isc.value, False)
            # 開啟 dl + cl + ct（車道 + 障礙偵測）
            self.fnLaunch(self.Launcher.dl.value, True)
            self.fnLaunch(self.Launcher.cl.value, True)
            self.fnLaunch(self.Launcher.ct.value, True)
            # detect_construction 偵測完障礙後會自動 pub /mission = Parking

        elif self.current_mode == self.Mission.Parking.value:  # 5
            rospy.loginfo("[Controller] === Parking ===")
            # 關閉 dl, cl, ct（不再需要巡線和障礙偵測）
            self.fnLaunch(self.Launcher.dl.value, False)
            self.fnLaunch(self.Launcher.cl.value, False)
            self.fnLaunch(self.Launcher.ct.value, False)
            # 等待停車場景景偵測啟動（pk 節點在 detect_parking 內部會一併處理）
            rospy.sleep(1)
            self.fnLaunch(self.Launcher.pk.value, True)
            # detect_parking 停車完成後會自動 pub /mission = LevelCrossing

        elif self.current_mode == self.Mission.LevelCrossing.value:  # 6
            rospy.loginfo("[Controller] === LevelCrossing ===")
            # 關閉 mv, pk, dl, cl
            self.fnLaunch(self.Launcher.mv.value, False)
            self.fnLaunch(self.Launcher.pk.value, False)
            self.fnLaunch(self.Launcher.dl.value, False)
            self.fnLaunch(self.Launcher.cl.value, False)
            # detect_level 會自己控制停止線邏輯，完成後 pub /mission = Tunnel
            self.fnLaunch(self.Launcher.lcro.value, True)

        elif self.current_mode == self.Mission.Tunnel.value:  # 7
            rospy.loginfo("[Controller] === Tunnel ===")
            self.fnLaunch(self.Launcher.lcro.value, False)
            self.fnLaunch(self.Launcher.dl.value, True)
            self.fnLaunch(self.Launcher.cl.value, True)
            # detect_tunnel 會控制車子前進 + 導航，完成後 pub /mission
            # 最後一個 mission，core_node_controller 不需要額外處理
            rospy.sleep(25)
            self.fnLaunch(self.Launcher.ctun.value, True)  # 啟動 move_base 導航
            self.fnLaunch(self.Launcher.dl.value, False)
            self.fnLaunch(self.Launcher.tun.value, True)
            rospy.sleep(2)
            self.fnLaunch(self.Launcher.mv.value, True)

        self.is_triggered = False

    def fnLaunch(self, launch_num, is_start):
        """對照 Launcher enum value 來啟動或關閉節點"""
        key_map = {
            self.Launcher.dl.value:    'dl',
            self.Launcher.cl.value:    'cl',
            self.Launcher.tf.value:    'tf',
            self.Launcher.isc.value:   'isc',
            self.Launcher.ct.value:    'ct',
            self.Launcher.pk.value:    'pk',
            self.Launcher.mv.value:    'mv',
            self.Launcher.lcro.value:  'lcro',
            self.Launcher.tun.value:   'tun',
            self.Launcher.ctun.value:  'ctun',
        }
        key = key_map.get(launch_num)
        if key is None:
            rospy.logwarn("[Controller] 未知 launch_num: %s", launch_num)
            return

        if is_start:
            if not self.launchers[key]['active']:
                launch_file = self._get_launch_file(key)
                if launch_file is None:
                    rospy.logwarn("[Controller] %s 沒有對應 launch 檔", key)
                    return
                handle = roslaunch.scriptapi.ROSLaunch()
                handle = roslaunch.parent.ROSLaunchParent(
                    self.uuid,
                    [self.ros_package_path + launch_file]
                )
                handle.start()
                self.launchers[key]['handle'] = handle
                self.launchers[key]['active'] = True
                rospy.loginfo("[Controller] 啟動 +++ %s", key)
            else:
                rospy.loginfo("[Controller] %s 已啟動（跳過）", key)
        else:
            if self.launchers[key]['active']:
                self.launchers[key]['handle'].shutdown()
                self.launchers[key]['handle'] = None
                self.launchers[key]['active'] = False
                rospy.loginfo("[Controller] 關閉 --- %s", key)
            else:
                rospy.loginfo("[Controller] %s 已關閉（跳過）", key)

    def _get_launch_file(self, key):
        mapping = {
            'dl':   'detect/launch/detect_lane.launch',
            'cl':   'control/launch/control_lane.launch',
            'tf':   'detect/launch/detect_traffic_light.launch',
            'isc':  'detect/launch/detect_intersection.launch',
            'ct':   'detect/launch/detect_construction.launch',
            'pk':   'detect/launch/detect_parking.launch',
            'mv':   'control/launch/control_moving.launch',
            'lcro': 'detect/launch/detect_level.launch',
            'tun':  'detect/launch/detect_tunnel.launch',
            'ctun': 'control/launch/control_tunnel.launch',
        }
        return mapping.get(key)

if __name__ == '__main__':
    rospy.init_node('core_node_controller')
    node = CoreNodeController()
    rospy.spin()
