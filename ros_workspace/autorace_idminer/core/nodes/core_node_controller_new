#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import rospy, roslaunch, os, signal, sys
from enum import Enum
from std_msgs.msg import UInt8

# 自訂 SIGINT handler：Ctrl+C 不立刻退出，等使用者看完訊息再按 Enter
def _sigint_handler(signum, frame):
    print("\n[Controller] 收到 Ctrl+C 已停止。訊息留著慢慢看，按 Enter 離開。")
    sys.stdout.flush()
    sys.exit(0)

signal.signal(signal.SIGINT, _sigint_handler)

class CoreNodeController():
    def __init__(self):
        self.ros_package_path = os.path.dirname(os.path.realpath(__file__))
        self.ros_package_path = self.ros_package_path.replace('core/nodes', '')

        # ========== Subscriber ==========
        # 監聽主要 mission（各 detect node 完成的訊號）
        self.sub_mission = rospy.Subscriber('/mission', UInt8, self.cbReceiveMode, queue_size=1)

        # 監聽 Tunnel 階段子訊號（detect_tunnel 內部狀態）
        self.sub_mission_tunnel = rospy.Subscriber('/mission/tunnel', UInt8, self.cbMissionTunnel, queue_size=1)

        # ========== Enum ==========
        self.Mission = Enum('Mission', 'Idle TrafficLight Intersection Construction Parking LevelCrossing Tunnel')
        self.TunnelStep = Enum('TunnelStep', 'default process nav end')

        # ========== State ==========
        self.is_triggered = False
        self.current_mode = self.Mission.Idle.value
        self.current_tunnel_step = self.TunnelStep.default.value

        # launcher enum
        # dl=detect_lane, cl=control_lane, tf=traffic_light,
        # isc=intersection, ct=construction, pk=parking,
        # mv=control_moving, lcro=level_crossing, tun=detect_tunnel,
        # ctun=control_tunnel(map_server+AMCL+move_base)
        self.Launcher = Enum('Launcher', 'dl cl tf isc ct pk mv lcro tun ctun')

        # 各節點啟動狀態
        self.launch_dl = False
        self.launch_cl = False
        self.launch_tf = False
        self.launch_isc = False
        self.launch_ct = False
        self.launch_pk = False
        self.launch_mv = False
        self.launch_lcro = False
        self.launch_tun = False
        self.launch_ctun = False

        self.uuid = roslaunch.rlutil.get_or_generate_uuid(None, False)

        rospy.loginfo("[Controller] ===== 啟動中 =====")

        loop_rate = rospy.Rate(10)  # 10hz

        while not rospy.is_shutdown():
            if self.is_triggered == True:
                self.fnControlNode()
            loop_rate.sleep()

    def cbReceiveMode(self, mode_msg):
        rospy.loginfo("[Controller] 收到 /mission = %d", mode_msg.data)
        self.current_mode = mode_msg.data
        self.is_triggered = True

    def cbMissionTunnel(self, tunnel_step_msg):
        """監聽 detect_tunnel 的內部狀態，驅動 Tunnel 關卡的子階段"""
        step = tunnel_step_msg.data
        rospy.loginfo("[Controller] 收到 /mission/tunnel = %d (current step: %d)", step, self.current_tunnel_step)

        # 防止重複處理同一個狀態
        if step == self.current_tunnel_step:
            return

        self.current_tunnel_step = step

        # 只有在 Tunnel 模式下才處理 tunnel 子階段
        if self.current_mode != self.Mission.Tunnel.value:
            return

        if step == self.TunnelStep.process.value:
            # detect_tunnel 看到 tunnel.png，前進 0.3m 完成
            # → 準備進入導航階段：開 ctun，關 dl/cl
            rospy.loginfo("[Controller] Tunnel: process → 開 ctun 導航，關 dl/cl")
            self.fnLaunch(self.Launcher.dl.value, False)
            self.fnLaunch(self.Launcher.cl.value, False)
            self.fnLaunch(self.Launcher.ctun.value, True)

        elif step == self.TunnelStep.nav.value:
            # ctun 導航中（move_base 正在移動），無需額外操作
            rospy.loginfo("[Controller] Tunnel: nav 導航中...")

        elif step == self.TunnelStep.end.value:
            # 到達出口，直線前進後 → 開 dl/cl/mv 恢復循線
            rospy.loginfo("[Controller] Tunnel: end → 開 dl/cl/mv 恢復循線")
            self.fnLaunch(self.Launcher.tun.value, False)
            self.fnLaunch(self.Launcher.ctun.value, False)
            self.fnLaunch(self.Launcher.dl.value, True)
            self.fnLaunch(self.Launcher.cl.value, True)
            self.fnLaunch(self.Launcher.mv.value, True)

    # ========== 各關卡控制邏輯 ==========
    def fnControlNode(self):

        if self.current_mode == self.Mission.TrafficLight.value:  # 2
            rospy.loginfo("[Controller] === TrafficLight ===")
            self.fnLaunch(self.Launcher.tf.value, True)

        elif self.current_mode == self.Mission.Intersection.value:  # 3
            rospy.loginfo("[Controller] === Intersection ===")
            self.fnLaunch(self.Launcher.dl.value, True)
            self.fnLaunch(self.Launcher.cl.value, True)
            self.fnLaunch(self.Launcher.tf.value, False)
            rospy.sleep(6)
            self.fnLaunch(self.Launcher.isc.value, True)

        elif self.current_mode == self.Mission.Construction.value:  # 4
            rospy.loginfo("[Controller] === Construction ===")
            self.fnLaunch(self.Launcher.isc.value, False)
            self.fnLaunch(self.Launcher.dl.value, True)
            self.fnLaunch(self.Launcher.cl.value, True)
            self.fnLaunch(self.Launcher.ct.value, True)
            rospy.sleep(6)
            self.fnLaunch(self.Launcher.mv.value, True)

        elif self.current_mode == self.Mission.Parking.value:  # 5
            rospy.loginfo("[Controller] === Parking ===")
            self.fnLaunch(self.Launcher.dl.value, True)     # 開啟 dl（循線，white toggle 受 control）
            self.fnLaunch(self.Launcher.cl.value, True)     # 開啟 cl
            self.fnLaunch(self.Launcher.ct.value, False)
            self.fnLaunch(self.Launcher.pk.value, True)     # pk 偵測到圖標後會 pub white_toggle=False
            self.fnLaunch(self.Launcher.mv.value, True)      # mv 由 detect_parking 直接控制

        elif self.current_mode == self.Mission.LevelCrossing.value:  # 6
            rospy.loginfo("[Controller] === LevelCrossing ===")
            self.fnLaunch(self.Launcher.mv.value, False)
            self.fnLaunch(self.Launcher.pk.value, False)
            self.fnLaunch(self.Launcher.dl.value, True)
            self.fnLaunch(self.Launcher.cl.value, True)
            rospy.sleep(12)
            self.fnLaunch(self.Launcher.lcro.value, True)

        elif self.current_mode == self.Mission.Tunnel.value:  # 7
            rospy.loginfo("[Controller] === Tunnel ===")
            # 重置 tunnel 子階段狀態
            self.current_tunnel_step = self.TunnelStep.default.value
            # Level 結束，開始 Tunnel：開 dl/cl + tun，關 lcro
            self.fnLaunch(self.Launcher.lcro.value, False)
            self.fnLaunch(self.Launcher.dl.value, True)
            self.fnLaunch(self.Launcher.cl.value, True)
            self.fnLaunch(self.Launcher.tun.value, True)
            # detect_tunnel 看到 tunnel.png → 發 /mission/tunnel = process
            # → cbMissionTunnel 收到後自動開 ctun、關 dl/cl
            # detect_tunnel 導航完成 → 發 /mission/tunnel = end
            # → cbMissionTunnel 收到後開 dl/cl/mv

        self.is_triggered = False

    # ========== 節點啟動/關閉 ==========
    def fnLaunch(self, launch_num, is_start):

        if launch_num == self.Launcher.dl.value:
            if is_start:
                if not self.launch_dl:
                    self.dl = roslaunch.scriptapi.ROSLaunch()
                    self.dl = roslaunch.parent.ROSLaunchParent(
                        self.uuid,
                        [self.ros_package_path + "detect/launch/detect_lane.launch"]
                    )
                    self.launch_dl = True
                    self.dl.start()
                    rospy.loginfo("[Controller] 啟動 ++ dl")
                else:
                    rospy.loginfo("[Controller] dl 已啟動（跳過）")
            else:
                if self.launch_dl:
                    self.dl.shutdown()
                    self.launch_dl = False
                    rospy.loginfo("[Controller] 關閉 -- dl")
