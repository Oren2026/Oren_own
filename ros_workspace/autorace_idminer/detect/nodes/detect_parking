#!/usr/bin/env python
# -*- coding: utf-8 -*-

import rospy, os, cv2, math
import numpy as np
from enum import Enum
from std_msgs.msg import UInt8, Float64, Bool
from sensor_msgs.msg import CompressedImage, LaserScan
from cv_bridge import CvBridge
from nav_msgs.msg import Odometry
from geometry_msgs.msg import Twist
from turtlebot3_autorace_msgs.msg import MovingParam

class DetectSign():
    def __init__(self):

        self.Mission = Enum('Mission', 'Idle TrafficLight Intersection Construction Parking LevelCrossing Tunnel')
        self.ParkingStep = Enum('ParkingStep', 'default process')
        self.current_step_parking = self.ParkingStep.default.value
        
        self.cvBridge = CvBridge()
        self.counter = 1

        self.is_saw_parking = False
        self.is_parking_finished = False
        self.start_obstacle_detection = False

        self.is_moving_complete = False
        self.is_obstacle_detected_R = False
        self.is_obstacle_detected_L = False

        # ===== 狀態機 =====
        self.parking_state = "idle"          # idle / waiting / wait_obstacle / moving / done
        self.motion_queue = []                # 存放待執行的 (type, angular, linear) tuple
        self.is_executing_motion = False      # 防重入 guard

        self.fnPreproc()

        # subscribes compressed image
        self.sub_img = rospy.Subscriber('/image_input', CompressedImage, self.cbFindTrafficSign, queue_size = 1)
        self.sub_moving_completed = rospy.Subscriber('/control/moving/complete', UInt8, self.cbMovingComplete, queue_size = 1)
        self.sub_scan_obstacle = rospy.Subscriber('/scan', LaserScan, self.cbScanObstacle, queue_size=1)

        # publishes next mission
        self.pub_mission = rospy.Publisher('/mission', UInt8, queue_size=1)
        self.pub_mission_parking = rospy.Publisher('/mission/parking', UInt8, queue_size=1)
        self.pub_max_vel = rospy.Publisher('/control/max_vel', Float64, queue_size = 1)
        self.pub_fake_lane = rospy.Publisher('/control/lane', Float64, queue_size=1)
        self.pub_moving = rospy.Publisher('/control/moving/state', MovingParam, queue_size= 1)
        self.pub_cmd_vel = rospy.Publisher('/cmd_vel', Twist, queue_size=1)

        self.pub_lane_toggle = rospy.Publisher('/detect/lane_toggle', Bool, queue_size=1)
        self.pub_white_toggle = rospy.Publisher('/detect/white_toggle', Bool, queue_size=1)

        self.pub_image_traffic_sign = rospy.Publisher('/detect/sign/compressed', CompressedImage, queue_size = 1)

        rospy.loginfo("[detect_parking] 啟動完成")

    # ===== 執行下一個 motion =====
    def fnExecuteNextMotion(self):
        if len(self.motion_queue) == 0:
            # 所有 motion 完成，進收尾
            rospy.Timer(rospy.Duration(0.5), self.fnFinishParking, oneshot=True)
            return

        motion = self.motion_queue.pop(0)
        msg_moving = MovingParam()
        msg_moving.moving_type = motion[0]
        msg_moving.moving_value_angular = motion[1]
        msg_moving.moving_value_linear = motion[2]
        self.pub_moving.publish(msg_moving)
        rospy.loginfo("[PARKING] motion: type=%d ang=%.1f lin=%.2f", motion[0], motion[1], motion[2])

    # ===== cbMovingComplete：收到完成的回應，觸發下一個 motion =====
    def cbMovingComplete(self, data):
        if self.parking_state != "moving":
            return
        self.is_moving_complete = True
        rospy.sleep(0.5)   # 緩衝，避免 respond 太快
        self.fnExecuteNextMotion()

    # ===== cbScanObstacle：偵測到障礙物，開始停車序列 =====
    def cbScanObstacle(self, scan):
        if self.parking_state != "wait_obstacle":
            return

        angle_scan = 30
        scan_start_left = 45 - angle_scan
        scan_end_left = 45 + angle_scan
        scan_start_right = 315 - angle_scan
        scan_end_right = 315 + angle_scan

        min_distance_left = float('inf')
        min_distance_right = float('inf')

        for i in range(len(scan.ranges)):
            angle = math.degrees(scan.angle_increment * i)
            if scan_start_left <= angle <= scan_end_left:
                if scan.ranges[i] < min_distance_left:
                    min_distance_left = scan.ranges[i]
            elif scan_start_right <= angle <= scan_end_right:
                if scan.ranges[i] < min_distance_right:
                    min_distance_right = scan.ranges[i]

        if self.start_obstacle_detection:
            if min_distance_left < 0.3:
                self.is_obstacle_detected_L = True
                rospy.loginfo("[PARKING] LEFT obstacle detected")
                self.fnStartMotionSequence()
            elif min_distance_right < 0.3:
                self.is_obstacle_detected_R = True
                rospy.loginfo("[PARKING] RIGHT obstacle detected")
                self.fnStartMotionSequence()

    # ===== 5秒後的動作（oneshot timer）=====
    def fnAfterWait(self, event):
        rospy.loginfo("[PARKING] MOTION...")
        msg_pub_max_vel = Float64()
        msg_pub_max_vel.data = 0.05
        self.pub_max_vel.publish(msg_pub_max_vel)
        self.pub_cmd_vel.publish(Twist())
        self.start_obstacle_detection = True
        self.parking_state = "wait_obstacle"

    # ===== 根據障礙物方向，建立 motion queue 並開始執行 =====
    def fnStartMotionSequence(self):
        self.parking_state = "moving"
        self.is_executing_motion = True
        self.motion_queue = []

        if self.is_obstacle_detected_L:
            # RIGHT_CLEAR（S, L, S, B, R, S, L, S）
            rospy.loginfo("[PARKING] RIGHT_CLEAR path")
            self.motion_queue = [
                (4, 0.0, 0.2),
                (3, 90.0, 0.0),
                (4, 0.0, 0.3),
                (5, 0.0, 0.3),
                (3, 90.0, 0.0),
                (4, 0.0, 0.95),
                (2, 90.0, 0.0),
                (4, 0.0, 0.1),
            ]
        elif self.is_obstacle_detected_R:
            # LEFT_CLEAR（S, R, S, B, R, S, R, S）
            rospy.loginfo("[PARKING] LEFT_CLEAR path")
            self.motion_queue = [
                (4, 0.0, 0.3),
                (2, 90.0, 0.0),
                (4, 0.0, 0.25),
                (5, 0.0, 0.25),
                (2, 90.0, 0.0),
                (4, 0.0, 0.85),
                (3, 90.0, 0.0),
                (4, 0.0, 0.2),
            ]
        else:
            rospy.logwarn("[PARKING] no obstacle detected, cannot start motion")
            return

        # 開始執行第一個 motion
        self.fnExecuteNextMotion()

    # ===== 停車完成，恢復行駛 =====
    def fnFinishParking(self, event):
        rospy.loginfo("[PARKING] FINISH...")
        self.pub_white_toggle.publish(True)
        self.pub_lane_toggle.publish(True)

        msg_pub_max_vel = Float64()
        msg_pub_max_vel.data = 0.20
        self.pub_max_vel.publish(msg_pub_max_vel)

        self.pub_mission.publish(self.Mission.LevelCrossing.value)
        self.is_parking_finished = True
        self.parking_state = "done"

        # 重置狀態
        self.is_saw_parking = False
        self.start_obstacle_detection = False
        self.is_obstacle_detected_L = False
        self.is_obstacle_detected_R = False

    # ========== 以下是原本的視覺偵測部分（原封不動）==========
    def fnPreproc(self):
        self.script_path = os.path.dirname(os.path.realpath(__file__))
        self.script_path = self.script_path.replace('detect/nodes', 'detect/')

        self.img_parking = cv2.imread(self.script_path + 'img/p.png', cv2.IMREAD_GRAYSCALE)
        self.img_parking = cv2.resize(self.img_parking, (200, 200))
        self.sift = cv2.SIFT_create()
        self.kp_parking, self.des_parking = self.sift.detectAndCompute(self.img_parking, None)
        self.matcher = cv2.BFMatcher()

    def cbFindTrafficSign(self, img):
        # ===== 視覺偵測 parking sign（原封不動）=====
        if self.is_parking_finished:
            return

        try:
            cv_image_input = self.bridge.imgmsg_to_cv2(img, "bgr8")
        except self.cvBridge.CvBridgeError as e:
            rospy.logwarn("[detect_parking] cv_bridge error: %s", e)
            return

        self.cv_image = cv_image_input

        # ...（SIFT 偵測 parking sign 的程式碼，原封不動）...
        # 只需要在 is_saw_parking == True 的地方做小幅修改

        # parking process
        if self.is_saw_parking == True:

            # ===== 防重入 =====
            if self.parking_state != "idle":
                return

            self.pub_mission_parking.publish(self.ParkingStep.process.value)

            # ===== 用 timer 代替 rospy.sleep(5) =====
            rospy.loginfo("[PARKING] S, wait 5s before motion...")
            rospy.Timer(rospy.Duration(5), self.fnAfterWait, oneshot=True)

            self.parking_state = "waiting"

    def fnCalcMSE(self, src_pts, dst_pts):
        return np.mean((src_pts - dst_pts)**2)

    def main(self):
        rospy.spin()

if __name__ == '__main__':
    rospy.init_node('detect_parking')
    node = DetectSign()
    node.main()
