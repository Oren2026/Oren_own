#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import rospy, cv2, numpy as np, os
from sensor_msgs.msg import Image
from geometry_msgs.msg import Pose
from std_msgs.msg import UInt8, Float32
from cv_bridge import CvBridge
from enum import Enum
import actionlib
from move_base_msgs.msg import MoveBaseAction, MoveBaseGoal
from math import sqrt

class TunnelState(Enum):
    Default = 0
    SawTunnel = 1
    MovingForward = 2
    WaitingNav = 3
    Finished = 4

class DetectTunnel():
    def __init__(self):
        self.bridge = CvBridge()
        self.script_path = os.path.dirname(os.path.realpath(__file__))
        self.script_path = self.script_path.replace('detect/nodes', 'detect/')

        # ========== 視覺相關 ==========
        self.tunnel_img = cv2.imread(self.script_path + 'img/tunnel.png', cv2.IMREAD_GRAYSCALE)
        if self.tunnel_img is None:
            rospy.logwarn("[detect_tunnel] 無法讀取 tunnel.png")
        else:
            self.tunnel_img = cv2.resize(self.tunnel_img, (320, 240))
            self.sift = cv2.SIFT_create()
            self.tunnel_kp, self.tunnel_desc = self.sift.detectAndCompute(self.tunnel_img, None)

        # BFMatcher with L2 distance (SIFT uses 128-dim descriptors)
        self.matcher = cv2.BFMatcher()

        # 攝影機解析度
        self.width = 640
        self.height = 480

        # ========== State ==========
        self.state = TunnelState.Default
        self.reliability = 0
        self.is_saw_tunnel = False

        # ========== 里程計 ==========
        self.current_x = 0.0
        self.current_y = 0.0
        self.start_x = 0.0
        self.start_y = 0.0

        # ========== ROS ==========
        self.sub_cam = rospy.Subscriber('/camera/image', Image, self.cbImage, queue_size=1)
        self.pub_mission_tunnel = rospy.Publisher('/mission/tunnel', UInt8, queue_size=1)

        # move_base action client for navigation
        self.ac = actionlib.SimpleActionClient('move_base', MoveBaseAction)
        rospy.loginfo("[detect_tunnel] 等待 move_base 伺服器...")
        self.ac.wait_for_server()
        rospy.loginfo("[detect_tunnel] move_base 就緒")

        # Tunnel 出口座標（比賽場地實測值，需校正）
        self.tunnel_exit_x = -0.5   # 隧道出口相對位置（公尺）
        self.tunnel_exit_y = 0.0

        # Tunn 內移動距離（從洞口到出口）
        self.tunnel_move_dist = 0.6  # 實測隧道長度（公尺）

        rospy.loginfo("[detect_tunnel] 啟動完成")

    def cbImage(self, img_msg):
        try:
            frame = self.bridge.imgmsg_to_cv2(img_msg, "bgr8")
        except Exception as e:
            rospy.logwarn("[detect_tunnel] cv_bridge 轉換失敗: %s", e)
            return

        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)

        if self.state == TunnelState.Default:
            match_ratio = self.fnCheckTunnel(gray)
            rospy.loginfo_throttle(1.0, "[detect_tunnel] Default: match_ratio=%.2f", match_ratio)
            if match_ratio > 0.5:
                rospy.loginfo("[detect_tunnel] 偵測到隧道！開始前進")
                self.state = TunnelState.SawTunnel
                self.fnPublishTunnelStep(UInt8(1))  # process

        elif self.state == TunnelState.SawTunnel:
            rospy.loginfo_throttle(1.0, "[detect_tunnel] SawTunnel: 前進中...")
            match_ratio = self.fnCheckTunnel(gray)
            if match_ratio > 0.5:
                rospy.loginfo("[detect_tunnel] 持續看到隧道，持續前進")
            else:
                rospy.loginfo("[detect_tunnel] 隧道消失（已通過洞口）")
                # 記錄通過洞口的里程
                self.start_x = self.current_x
                self.start_y = self.current_y
                self.state = TunnelState.MovingForward

        elif self.state == TunnelState.MovingForward:
            dist = self.fnGetDistance()
            rospy.loginfo_throttle(0.5, "[detect_tunnel] MovingForward: 已行進 %.2f / %.2f m", dist, self.tunnel_move_dist)
            if dist >= self.tunnel_move_dist:
                rospy.loginfo("[detect_tunnel] 前進完成，開始導航通過")
                self.fnPublishTunnelStep(UInt8(2))  # nav
                self.state = TunnelState.WaitingNav
                self.fnNavigateThrough()
            else:
                # 尚未前進足夠，繼續前進（可用簡單 cmd_vel 直行）
                pass

        elif self.state == TunnelState.WaitingNav:
            # move_base 在背景執行，這裡只是等待完成
            # fnNavigateThrough 已送出 goal，透過 action client 回呼處理
            pass

        elif self.state == TunnelState.Finished:
            pass

    def fnCheckTunnel(self, gray):
        """使用 SIFT 比對 tunnel.png，回傳匹配分數（0~1）"""
        if self.tunnel_img is None:
            return 0.0

        try:
            kp, desc = self.sift.detectAndCompute(gray, None)
            if desc is None or len(kp) < 5:
                return 0.0

            matches = self.matcher.knnMatch(self.tunnel_desc, desc, k=2)
            good = []
            for m_n in matches:
                if len(m_n) != 2:
                    continue
                m, n = m_n
                if m.distance < 0.75 * n.distance:
                    good.append(m)

            # SIFT 匹配數量門檻
            score = len(good) / max(len(self.tunnel_kp), 1)
            return score
        except Exception as e:
            rospy.logwarn("[detect_tunnel] SIFT 比對失敗: %s", e)
            return 0.0

    def fnPublishTunnelStep(self, msg):
        """發布 Tunnel 階段（process=1, nav=2, end=3）"""
        self.pub_mission_tunnel.publish(msg)
        rospy.loginfo("[detect_tunnel] 發布 /mission/tunnel = %d", msg.data)

    def fnNavigateThrough(self):
        """透過 move_base 導航到隧道出口"""
        goal = MoveBaseGoal()
        goal.target_pose.header.frame_id = "map"
        goal.target_pose.header.stamp = rospy.Time.now()
        goal.target_pose.pose.position.x = self.current_x + self.tunnel_exit_x
        goal.target_pose.pose.position.y = self.current_y + self.tunnel_exit_y
        goal.target_pose.pose.orientation.w = 1.0

        rospy.loginfo("[detect_tunnel] 發送 move_base goal: (%.2f, %.2f)",
                      goal.target_pose.pose.position.x,
                      goal.target_pose.pose.position.y)

        self.ac.send_goal(goal,
                          done_cb=self.fnNavDoneCallback,
                          feedback_cb=self.fnNavFeedbackCallback)

    def fnNavDoneCallback(self, state, result):
        """move_base 完成後回呼"""
        rospy.loginfo("[detect_tunnel] move_base 完成，state=%d", state)
        self.fnPublishTunnelStep(UInt8(3))  # end
        self.state = TunnelState.Finished

    def fnNavFeedbackCallback(self, feedback):
        """move_base 執行中回呼"""
        pass

    def fnGetDistance(self):
        """取得相對於 start_x/start_y 的移動距離"""
        dx = self.current_x - self.start_x
        dy = self.current_y - self.start_y
        return sqrt(dx*dx + dy*dy)

if __name__ == '__main__':
    rospy.init_node('detect_tunnel')
    node = DetectTunnel()
    rospy.spin()
