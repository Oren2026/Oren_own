    def cbScanObstacle(self, scan):
        """
        雷達障礙偵測：
        - 同時監控左側（45-75°）和右側（285-315°）障礙物
        - 當左右兩側障礙物都 < threshold，代表抵達隧道入口對稱點
        - 同時持續監控前方障礙物距離，用於動態調速

        [此函式保留但目前不用，純命令模式不需要 LiDAR 偵測]
        """
        angle_scan_side = 15   # 左右掃描範圍（度）
        threshold_symmetry = 0.35   # 對稱點門檻（35cm，兩側都低於此值 = 對稱停車點）
        threshold_front = 0.4      # 前方障礙物門檻

        # 左側：45-75°（前方左側）
        scan_start_left = 45
        scan_end_left = 75
        # 右側：285-315°（前方右側）
        scan_start_right = 285
        scan_end_right = 315

        min_left = float('inf')
        for i in range(scan_start_left, scan_end_left):
            if scan.ranges[i] > 0.2:
                min_left = min(min_left, scan.ranges[i])

        min_right = float('inf')
        for i in range(scan_start_right, scan_end_right):
            if scan.ranges[i] > 0.2:
                min_right = min(min_right, scan.ranges[i])

        # 前方障礙物（用於調速）
        scan_start_front = 355
        scan_end_front = 5
        min_front = float('inf')
        for i in list(range(scan_start_front, 360)) + list(range(0, scan_end_front)):
            if scan.ranges[i] > 0.2:
                min_front = min(min_front, scan.ranges[i])

        self.left_range = min_left if min_left != float('inf') else 1.0
        self.right_range = min_right if min_right != float('inf') else 1.0
        self.obstacle_range = min_front if min_front != float('inf') else 1.0

        # 對稱點判斷：左右都低於門檻
        if min_left < threshold_symmetry and min_right < threshold_symmetry:
            if not self.is_at_tunnel_entry:
                rospy.loginfo("[TUNNEL] AT TUNNEL ENTRY (symmetry detected: L=%.3f R=%.3f)",
                              self.left_range, self.right_range)
            self.is_at_tunnel_entry = True

        # 前方障礙物偵測
        self.is_obstacle_detected = (min_front < threshold_front)

        if self.is_obstacle_detected:
            rospy.loginfo("[TUNNEL] OBSTACLE: front=%.3f", self.obstacle_range)

