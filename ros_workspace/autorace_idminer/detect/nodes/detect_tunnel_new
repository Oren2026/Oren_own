    def fnCalcMSE(self, arr1, arr2):
        """
        [不使用] MSE 計算，用於 SIFT 特徵比對，純命令模式不需要。
        """
        squared_diff = (arr1 - arr2) ** 2
        sum = np.sum(squared_diff)
        num_all = arr1.shape[0] * arr1.shape[1]
        err = sum / num_all
        return err

