        [不使用] 隧道結束回調。
        """
        self.is_tunnel_finished = True

    # =========================================================================
    # 純命令模式：不靠視覺偵測洞口，直接用 detect_moving 指令序列
    #
    # 使用方式：
    #   1. 開啟 detect_moving（MOVING 按鈕）
    #   2. 開啟本節點（m7cal / m7隧道（新））
    #   3. 等待指令序列跑完
    #
    # 指令格式（MovingParam）：
    #   moving_type:
    #     2 = 原地旋轉（moving_value_angular = 角度 °）
    #     3 = 原地旋轉（moving_value_angular = 角度 °，同 type=2）
    #     4 = 直線前進（moving_value_linear = 距離 m）
    #
    # 等待完成：每次 publish 後 while is_moving_complete == False，等待 /control/moving/complete 發回 1
    # =========================================================================

    def fnSendMoving(self, moving_type, linear, angular):
        """
        發送一筆 MovingParam 並等待完成。
        """
        msg = MovingParam()
        msg.moving_type = moving_type
        msg.moving_value_linear = linear
        msg.moving_value_angular = angular
        self.pub_moving.publish(msg)
        rospy.loginfo("[TUNNEL] moving_type=%d linear=%.2f angular=%.2f",
                      moving_type, linear, angular)
        while not rospy.is_shutdown() and not self.is_moving_complete:
            rospy.sleep(0.1)
        self.is_moving_complete = False
        rospy.sleep(0.5)  # 緩衝

    def main(self):
        """
        純命令驅動模式：
        開啟後直接執行隧道穿越指令序列，不等待視覺偵測。
        """
        rospy.loginfo("[TUNNEL] === PURE COMMAND MODE (detect_moving) ===")
        rospy.loginfo("[TUNNEL] Waiting for detect_moving to be ready...")

        # 等 detect_moving 啟動完成（延遲 3 秒）
        rospy.sleep(3)

        # =====================================================================
        # 隧道穿越指令序列（7 steps）：
        #   S(0.5) → L(90°) → S(1.7) → R(90°) → S(1.2) → L(90°) → S(0.1)
        # =====================================================================
        rospy.loginfo("[TUNNEL] === STEP 1: S 0.5m ===")
        self.fnSendMoving(moving_type=4, linear=0.5, angular=0.0)

        rospy.loginfo("[TUNNEL] === STEP 2: L 90° ===")
        self.fnSendMoving(moving_type=2, linear=0.0, angular=90.0)

        rospy.loginfo("[TUNNEL] === STEP 3: S 1.7m ===")
        self.fnSendMoving(moving_type=4, linear=1.7, angular=0.0)

        rospy.loginfo("[TUNNEL] === STEP 4: R 90° ===")
        self.fnSendMoving(moving_type=3, linear=0.0, angular=90.0)

        rospy.loginfo("[TUNNEL] === STEP 5: S 1.2m ===")
        self.fnSendMoving(moving_type=4, linear=1.2, angular=0.0)

        rospy.loginfo("[TUNNEL] === STEP 6: L 90° ===")
        self.fnSendMoving(moving_type=2, linear=0.0, angular=90.0)

        rospy.loginfo("[TUNNEL] === STEP 7: S 0.1m (final) ===")
        self.fnSendMoving(moving_type=4, linear=0.1, angular=0.0)

        # =====================================================================
        # 完成：重啟循線（dl + cl），然後發布結束訊號
        # =====================================================================
        rospy.loginfo("[TUNNEL] === ALL STEPS DONE, RESTARTING LANE FOLLOWING ===")

        # 用 subprocess 啟動 dl + cl（detect_lane + control_lane）
        import subprocess, os
        env = os.environ.copy()
        env['ROS_PACKAGE_PATH'] = '/home/autorace/catkin_ws/src:/opt/ros/kinetic/share'

        subprocess.Popen(
            ['bash', '-c',
             'source ~/catkin_ws/devel/setup.bash && roslaunch detect detect_lane.launch & wait'],
            env=env, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
            start_new_session=True
        )
        rospy.sleep(1)
        subprocess.Popen(
            ['bash', '-c',
             'source ~/catkin_ws/devel/setup.bash && roslaunch control control_lane.launch & wait'],
            env=env, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
            start_new_session=True
        )
        rospy.sleep(2)  # 等 dl/cl 啟動

        rospy.loginfo("[TUNNEL] === LANE FOLLOWING RESTARTED, PUBLISHING MISSION END ===")
        self.pub_mission_tunnel.publish(self.TunnelStep.end.value)
        self.pub_mission.publish(UInt8(0))  # 回 idle

